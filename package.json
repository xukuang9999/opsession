{
  "name": "openclaw-superposition-demo",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "test": "./node_modules/.bin/tsx scripts/check-data-catalog.ts",
    "test:e2e": "npm run build && ./node_modules/.bin/tsx scripts/check-e2e.ts",
    "check": "npm run build && npm run check:rooms && npm run check:layout && npm run test",
    "preview": "vite preview",
    "check:rooms": "node scripts/check-room-accessibility.mjs",
    "check:layout": "node scripts/check-layout-regression.mjs",
    "optimize:office": "node scripts/optimize-office-layout.mjs --write"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^7.1.12"
  }
}
